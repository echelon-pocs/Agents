# Hermes Agent — secrets template
# Copy to .env for local testing. For Modal production, use:
#   modal secret create hermes-secrets OPENROUTER_API_KEY=... ...

# OpenRouter API key — get from https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Telegram bot token — from @BotFather → /newbot
TELEGRAM_BOT_TOKEN=

# Your Telegram chat ID — optional; restricts the bot to owner only.
# Get it by messaging @userinfobot on Telegram.
# Leave empty to allow any user (not recommended for personal agents).
TELEGRAM_CHAT_ID=
